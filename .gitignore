MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
/*.manifest
/*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit tests / coverage reports
htmlcov/
.tox/
.nosexy
.noseids
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
venv/
.venv/
env/
.env
bin/
lib/

# Jupyter Notebook checkpoints
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# IPython
.ipython/

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you might want to ignore it.
# .python-version

# pipenv
#   According to pypa/pipenv#1017, pipenv should not be ignored.
#   However, if you're executing it, you can ignore the Pipfile.lock.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally committed, but can be ignored.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally committed, but can be ignored.
# pdm.lock

